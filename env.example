# ─────────────────────────────────────────────
#  .env files per client
#  Save each of these as separate files.
#  NEVER commit these to GitHub.
# ─────────────────────────────────────────────

# ──────────────────────────────────────────────
#  .env.innovesia  (Innovesia — original client)
# ──────────────────────────────────────────────
VITE_CLIENT_ID=innovesia
VITE_SUPABASE_URL=https://qzqipvrepkpmxelohitb.supabase.co
VITE_SUPABASE_ANON_KEY=<innovesia-anon-key>
VITE_ONESIGNAL_APP_ID=<innovesia-onesignal-app-id>


# ──────────────────────────────────────────────
#  .env.acme  (Acme Corp — new client)
# ──────────────────────────────────────────────
VITE_CLIENT_ID=acme
VITE_SUPABASE_URL=https://<acme-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<acme-anon-key>
VITE_ONESIGNAL_APP_ID=<acme-onesignal-app-id>


# ──────────────────────────────────────────────
#  HOW TO USE LOCALLY
#  Copy the file you want as .env.local before running dev:
#
#    cp .env.innovesia .env.local && npm run dev   ← run as Innovesia
#    cp .env.acme .env.local && npm run dev        ← run as Acme
#
#  ON VERCEL:
#  Each client gets their OWN Vercel project.
#  Add VITE_CLIENT_ID and the Supabase/OneSignal keys
#  directly in Vercel → Project → Settings → Environment Variables.
# ──────────────────────────────────────────────
